# 文档用途：后端服务环境变量示例
# 文档内容：FastAPI、SQLite、MinIO、上传限制、视频处理配置
# 内容来源：AI自动生成，项目团队确认
# 更新方式：后端新增配置时必须同步更新，并为新增/修改变量补充注释
# 备注：复制为 .env 使用，真实 .env 禁止提交

# 运行环境：development / staging / production；production 必须配置 MySQL DATABASE_URL。
APP_ENV=development
# 日志级别：DEBUG / INFO / WARNING / ERROR。
LOG_LEVEL=INFO
# 后端 FastAPI 监听地址。
BACKEND_HOST=0.0.0.0
# 后端监听端口；本地直连开发时使用。
BACKEND_PORT=8000
# 允许跨域的前端 Origin 列表，逗号分隔（含 Vite 5173 与 Docker Web 3000）。
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# 统一数据库连接 URL；非生产为空时回退 SQLITE_DATABASE_URL。
# 生产示例：mysql+pymysql://tiles_user:replace-with-secret@mysql.example.com:3306/tilesfst?charset=utf8mb4
DATABASE_URL=
# SQLite 数据库连接 URL；仅用于本地开发、测试和演示。
SQLITE_DATABASE_URL=sqlite:///./data/sqlite/tile_info.db
# MinIO 服务地址；本地非 Docker 时为 localhost:9000，外部 MinIO 场景使用外部 host:port。
MINIO_ENDPOINT=localhost:9000
# MinIO 访问密钥。
MINIO_ACCESS_KEY=minioadmin
# MinIO 秘密密钥；示例值仅用于本地。
MINIO_SECRET_KEY=minioadmin123
# 是否使用 HTTPS 连接 MinIO；外部 MinIO/S3 兼容服务通常为 true。
MINIO_SECURE=false
# 单张图片上传大小上限（MB）。
MAX_IMAGE_SIZE_MB=20
# 单个视频上传大小上限（MB）。
MAX_VIDEO_SIZE_MB=500
# 允许的图片 MIME 类型，逗号分隔。
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/jpg
# 允许的视频 MIME 类型，逗号分隔。
ALLOWED_VIDEO_TYPES=video/mp4,video/quicktime,video/x-msvideo
# MinIO 单桶名；外部 MinIO 场景需运维提前创建。
MINIO_BUCKET=tile-info-platform
# 图片类上传对象前缀。
MINIO_PREFIX_IMAGES=images/
# Deprecated：legacy 图片前缀。
MINIO_PREFIX_ORIGINAL=original/
# 视频原文件对象前缀。
MINIO_PREFIX_VIDEO=videos/
# JWT 签名密钥；生产 MUST 更换。
APP_SECRET_KEY=change-me-in-local-env
# JWT 访问令牌有效期（分钟）。
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
# JWT 访问令牌有效期（天）；「记住我」登录时使用。
JWT_REMEMBER_ME_EXPIRE_DAYS=7
# 默认管理员用户名。
ADMIN_USERNAME=admin
# 默认管理员初始密码。
ADMIN_INITIAL_PASSWORD=change-me-on-first-run
# 是否在服务启动时重置 admin 密码为 ADMIN_INITIAL_PASSWORD；默认 false。
ADMIN_RESET_PASSWORD_ON_STARTUP=false
