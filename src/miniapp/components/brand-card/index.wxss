.brand-card {
  min-height: 104rpx;
  display: grid;
  grid-template-columns: 64rpx minmax(0, 1fr) 28rpx;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(200,160,85,0.2);
  border-radius: 16rpx;
  background: #211E16;
  box-shadow: 0 12rpx 34rpx rgba(0,0,0,0.18);
  box-sizing: border-box;
  overflow: hidden;
}

.brand-card-press {
  opacity: 0.72;
}

.brand-card.unavailable {
  border-color: rgba(255,255,255,0.08);
  opacity: 0.72;
}

.brand-card.grid {
  min-height: 244rpx;
  grid-template-columns: minmax(0, 1fr);
  justify-items: center;
  align-content: start;
  gap: 14rpx;
  padding: 24rpx 18rpx 20rpx;
  border-radius: 8rpx;
  text-align: center;
}

.brand-logo-frame,
.brand-logo-image,
.brand-logo-empty {
  width: 64rpx;
  height: 64rpx;
}

.brand-card.grid .brand-logo-frame,
.brand-card.grid .brand-logo-image,
.brand-card.grid .brand-logo-empty {
  width: 92rpx;
  height: 92rpx;
}

.brand-logo-frame {
  overflow: hidden;
  border: 1rpx solid rgba(200,160,85,0.26);
  border-radius: 50%;
  background: #2A261D;
  box-sizing: border-box;
}

.brand-logo-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(200,160,85,0.12);
  color: #C8A055;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.brand-copy {
  min-width: 0;
}

.brand-card.grid .brand-copy {
  width: 100%;
}

.brand-name {
  color: #EDE8DF;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.brand-card.grid .brand-name {
  min-height: 72rpx;
  white-space: normal;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.brand-hint {
  margin-top: 6rpx;
  color: rgba(237,232,223,0.56);
  font-size: 22rpx;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.brand-card.grid .brand-hint {
  min-height: 62rpx;
  white-space: normal;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.brand-arrow {
  color: #C8A055;
  font-size: 38rpx;
  line-height: 1;
  text-align: center;
}

.brand-card.grid .brand-arrow {
  display: none;
}

.brand-card.unavailable .brand-arrow {
  color: rgba(237,232,223,0.34);
}
