.product-card {
  min-height: 188rpx;
  display: flex;
  gap: 18rpx;
  padding: 16rpx;
  border-radius: 8rpx;
  background: #211E16;
  border: 2rpx solid rgba(255,255,255,0.07);
  box-sizing: border-box;
  overflow: hidden;
}

.product-card.card-press,
.card-press {
  opacity: 0.72;
}

.product-card.disabled {
  opacity: 0.58;
}

.product-image-frame {
  position: relative;
  width: 156rpx;
  height: 156rpx;
  flex: 0 0 156rpx;
  overflow: hidden;
  border-radius: 6rpx;
  background: #2A261D;
}

.product-image,
.product-image-empty {
  width: 100%;
  height: 100%;
}

.product-image-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    linear-gradient(135deg, rgba(200,160,85,0.18), transparent 42%),
    linear-gradient(160deg, #4B473B, #17150F);
  color: rgba(237,232,223,0.42);
  font-size: 22rpx;
}

.product-badge {
  position: absolute;
  left: 10rpx;
  top: 10rpx;
  max-width: 120rpx;
  min-height: 34rpx;
  padding: 0 10rpx;
  border: 1rpx solid rgba(200,160,85,0.32);
  background: rgba(24,22,15,0.72);
  color: #C8A055;
  font-size: 18rpx;
  line-height: 34rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-content {
  min-width: 0;
  flex: 1;
}

.product-brand {
  margin-top: 10rpx;
  color: #C8A055;
  font-size: 22rpx;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-name {
  color: #EDE8DF;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.36;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-spec {
  margin-top: 8rpx;
  color: rgba(237,232,223,0.52);
  font-size: 22rpx;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-price {
  margin-top: 10rpx;
  color: #C8A055;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.3;
}

.product-price text {
  margin-right: 8rpx;
  color: rgba(237,232,223,0.56);
  font-size: 20rpx;
  font-weight: 400;
}

.product-card.compact,
.product-card.grid {
  display: block;
  min-height: 0;
  padding: 0;
}

.product-card.compact .product-image-frame,
.product-card.grid .product-image-frame {
  width: 100%;
  height: auto;
  aspect-ratio: 1 / 0.86;
  border-radius: 0;
}

.product-card.compact .product-content,
.product-card.grid .product-content {
  padding: 14rpx;
}

.product-card.compact {
  width: 248rpx;
  display: inline-block;
  margin-right: 20rpx;
  vertical-align: top;
}

.product-card.grid {
  width: 100%;
}
