.search-entry {
  display: flex;
  align-items: center;
  gap: 14rpx;
  width: 100%;
  min-height: 88rpx;
}

.entry-back,
.entry-clear {
  width: 88rpx;
  height: 88rpx;
  padding: 0;
  border-radius: 44rpx;
  background: #252116;
  color: #E7D7B8;
  font-size: 36rpx;
  line-height: 88rpx;
}

.entry-box {
  flex: 1;
  min-width: 0;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 18rpx;
  border: 1rpx solid rgba(200, 160, 85, 0.35);
  border-radius: 44rpx;
  background: #221F16;
  box-sizing: border-box;
}

.entry-icon {
  margin-right: 10rpx;
  color: #C8A055;
}

.entry-input {
  flex: 1;
  min-height: 80rpx;
  color: #FFF7E8;
  font-size: 28rpx;
}

.entry-submit {
  min-width: 120rpx;
  min-height: 88rpx;
  border-radius: 44rpx;
  background: #C8A055;
  color: #18160F;
  font-size: 26rpx;
  font-weight: 700;
}

.disabled {
  opacity: 0.56;
}
