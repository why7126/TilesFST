.search-entry {
  display: flex;
  align-items: center;
  gap: 14rpx;
  width: 100%;
  min-height: 88rpx;
}

.entry-back {
  width: 88rpx;
  height: 88rpx;
  padding: 0;
  border-radius: 44rpx;
  background: #252116;
  color: #E7D7B8;
  font-size: 36rpx;
  line-height: 88rpx;
}

.entry-shell {
  flex: 1;
  min-width: 0;
  min-height: 88rpx;
  padding: 0 16rpx 0 28rpx;
  border: 2rpx solid rgba(255,255,255,0.07);
  border-radius: 44rpx;
  background: #211E16;
  color: rgba(237,232,223,0.5);
  font-size: 26rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.entry-box {
  flex: 1;
  min-width: 0;
  min-height: 80rpx;
  display: flex;
  align-items: center;
}

.entry-input {
  flex: 1;
  min-height: 80rpx;
  color: #EDE8DF;
  font-size: 26rpx;
}

.entry-clear {
  width: 64rpx;
  height: 64rpx;
  padding: 0;
  border-radius: 32rpx;
  background: transparent;
  color: #E7D7B8;
  font-size: 32rpx;
  line-height: 64rpx;
}

.disabled {
  opacity: 0.56;
}
