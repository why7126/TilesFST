<view class="search-entry {{disabled ? 'disabled' : ''}}">
  <button wx:if="{{showBack}}" class="entry-back" bindtap="onCancel">‹</button>
  <view class="entry-shell">
    <view class="entry-box">
      <input
        class="entry-input"
        disabled="{{disabled}}"
        value="{{keyword}}"
        placeholder="{{placeholder}}"
        confirm-type="search"
        bindinput="onInput"
        bindconfirm="onSubmit"
      />
      <button wx:if="{{keyword && !disabled}}" class="entry-clear" bindtap="onClear">×</button>
    </view>
  </view>
</view>
