<view class="custom-navigation-spacer" style="height: {{navHeight}}px;"></view>
<view class="custom-navigation {{variant === 'home' ? 'home' : 'subpage'}}" style="{{navBarStyle}}">
  <view wx:if="{{variant !== 'home'}}" class="back-hit-area" bindtap="handleBack" aria-label="返回">
    <text class="back-icon">‹</text>
  </view>

  <view wx:if="{{variant === 'home'}}" class="brand-identity">
    <image class="store-logo" src="{{logoSrc || '/assets/logos/product-logo.png'}}" mode="aspectFill"></image>
    <view class="store-copy">
      <view class="store-name">菲尚特瓷砖馆</view>
      <view class="store-subtitle">质感空间，由砖而生</view>
    </view>
  </view>

  <view wx:else class="subpage-copy">
    <view class="subpage-title">{{title || '菲尚特瓷砖'}}</view>
  </view>

  <view class="native-action-reserve" style="{{reserveStyle}}"></view>
</view>
