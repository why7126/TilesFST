.custom-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  min-height: 112rpx;
  padding: 10rpx 28rpx calc(12rpx + env(safe-area-inset-bottom));
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  background: rgba(24,22,15,0.98);
  border-top: 2rpx solid rgba(255,255,255,0.07);
  box-sizing: border-box;
}

.tabbar-item {
  min-height: 88rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: rgba(237,232,223,0.5);
  font-size: 24rpx;
  font-weight: 600;
}

.tabbar-item.active {
  color: #C8A055;
  font-weight: 800;
}

.tabbar-icon {
  width: 46rpx;
  height: 46rpx;
  margin-bottom: 6rpx;
}

.tabbar-text {
  line-height: 1.2;
}
