.page {
  min-height: 100vh;
  padding: 28rpx 28rpx calc(132rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #18160F;
  color: #EDE8DF;
}

.brand-hero,
.detail-skeleton {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 8rpx;
  background: #211E16;
  border: 2rpx solid rgba(255,255,255,0.07);
  box-sizing: border-box;
}

.brand-hero {
  margin-top: 12rpx;
  padding: 0;
  overflow: hidden;
}

.brand-logo-frame,
.brand-logo,
.brand-logo-empty,
.hero-skeleton {
  width: 100%;
  height: 380rpx;
  border-radius: 8rpx;
}

.brand-logo-frame {
  position: relative;
  overflow: hidden;
  background: #2A261D;
}

.brand-logo-empty,
.hero-skeleton {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(160deg, #4B473B, #17150F);
  color: #C8A055;
  font-size: 42rpx;
  font-weight: 800;
}

.brand-copy {
  min-width: 0;
}

.brand-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
  padding: 72rpx 24rpx 24rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, rgba(24,22,15,0), rgba(24,22,15,0.88));
}

.brand-hero .brand-name {
  color: #EDE8DF;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.25;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.brand-en,
.brand-description {
  margin-top: 10rpx;
  color: rgba(255,247,232,0.78);
  font-size: 24rpx;
  line-height: 1.55;
}

.brand-description {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.tab-scroll {
  position: sticky;
  top: 124rpx;
  z-index: 10;
  width: 100%;
  white-space: nowrap;
  margin-top: 24rpx;
  padding: 8rpx 0;
  background: rgba(24,22,15,0.96);
}

.tab {
  display: inline-flex;
  min-width: 132rpx;
  min-height: 68rpx;
  margin-right: 12rpx;
  align-items: center;
  justify-content: center;
  border-radius: 34rpx;
  background: #252116;
  color: #CFC2A8;
  font-size: 24rpx;
  font-weight: 400;
  line-height: 68rpx;
}

.tab.active {
  border: 1rpx solid #C8A055;
  background: rgba(200,160,85,0.18);
  color: #F1D99B;
}

.tab-panel {
  margin-top: 24rpx;
}

.product-grid,
.skeleton-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.skeleton-card {
  min-height: 334rpx;
  border-radius: 8rpx;
  background: rgba(33,30,22,0.74);
  border: 2rpx solid rgba(255,255,255,0.07);
}

.line {
  height: 26rpx;
  margin-top: 18rpx;
  border-radius: 8rpx;
  background: rgba(237,232,223,0.08);
}

.line.strong {
  width: 72%;
}

.state {
  min-height: 560rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  color: rgba(237,232,223,0.58);
  font-size: 26rpx;
  line-height: 1.5;
  text-align: center;
}

.state.compact {
  min-height: 280rpx;
}

.retry-btn {
  min-height: 84rpx;
  margin-top: 28rpx;
  padding: 0 36rpx;
  border-radius: 8rpx;
  background: #C8A055;
  color: #18160F;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 84rpx;
}

.load-more {
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(237,232,223,0.48);
  font-size: 24rpx;
}

.load-more.retry {
  color: #C8A055;
}

.certificate-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
  align-items: start;
}

.certificate-card {
  min-width: 0;
  overflow: hidden;
  border-radius: 18rpx;
  background: rgba(33,30,22,0.78);
  border: 2rpx solid rgba(255,255,255,0.07);
}

.file-frame {
  position: relative;
  width: 100%;
  overflow: hidden;
  aspect-ratio: 1 / 0.7;
  background: rgba(237,232,223,0.08);
}

.file-image {
  width: 100%;
  height: 100%;
}

.file-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(237,232,223,0.54);
  font-size: 30rpx;
  letter-spacing: 0;
}

.file-placeholder.pdf {
  color: #C8A055;
  background: rgba(200,160,85,0.1);
  font-weight: 800;
}

.card-body {
  min-height: 174rpx;
  padding: 18rpx;
  box-sizing: border-box;
}

.certificate-name {
  color: #EDE8DF;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.35;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  word-break: break-all;
}

.certificate-card .brand-name {
  margin-top: 10rpx;
  color: rgba(237,232,223,0.68);
  font-size: 23rpx;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.type-badge {
  max-width: 100%;
  margin-top: 12rpx;
  display: inline-flex;
  min-height: 40rpx;
  padding: 0 12rpx;
  align-items: center;
  border-radius: 20rpx;
  background: rgba(200,160,85,0.16);
  color: #C8A055;
  font-size: 21rpx;
  line-height: 40rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  box-sizing: border-box;
}

.card-press {
  opacity: 0.78;
}
