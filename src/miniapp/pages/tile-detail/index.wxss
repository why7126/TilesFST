.page {
  min-height: 100vh;
  padding-bottom: 150rpx;
  background: #18160F;
  color: #EDE8DF;
  overflow-x: hidden;
}

.content {
  padding-bottom: 24rpx;
}

.media-wrap {
  position: relative;
  min-height: 680rpx;
  background: #211E16;
}

.gallery,
.gallery-image,
.image-empty {
  width: 100%;
  height: 680rpx;
}

.gallery-image {
  display: block;
  background: #211E16;
}

.image-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8D836F;
  font-size: 28rpx;
}

.media-count,
.media-error {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 22rpx;
  background: rgba(24,22,15,0.82);
  color: #EDE8DF;
  font-size: 22rpx;
  line-height: 44rpx;
}

.media-error {
  left: 24rpx;
  right: auto;
  color: #C8A055;
}

.brand-card-wrap,
.summary,
.panel {
  margin: 22rpx 26rpx 0;
  border: 1rpx solid rgba(200,160,85,0.2);
  border-radius: 16rpx;
  background: #211E16;
  box-shadow: 0 12rpx 34rpx rgba(0,0,0,0.18);
}

.brand-card-wrap {
  border: 0;
  background: transparent;
  box-shadow: none;
}

.summary {
  padding: 28rpx;
}

.product-name {
  color: #F7F1E6;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.22;
}

.sku {
  margin-top: 12rpx;
  color: #AFA58E;
  font-size: 24rpx;
}

.price {
  margin-top: 22rpx;
  color: #C8A055;
  font-size: 38rpx;
  font-weight: 800;
}

.price-note {
  margin-top: 8rpx;
  color: #8D836F;
  font-size: 22rpx;
}

.panel {
  padding: 26rpx;
}

.panel-title {
  margin-bottom: 18rpx;
  color: #F7F1E6;
  font-size: 30rpx;
  font-weight: 700;
}

.field {
  min-height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  border-bottom: 1rpx solid rgba(237,232,223,0.08);
  color: #AFA58E;
  font-size: 25rpx;
}

.field:last-child {
  border-bottom: 0;
}

.field text:last-child {
  max-width: 430rpx;
  color: #EDE8DF;
  text-align: right;
  word-break: break-all;
}

.remark {
  color: #D8D0BE;
  font-size: 26rpx;
  line-height: 1.7;
  white-space: pre-wrap;
}

.recommend-row {
  width: 100%;
  white-space: nowrap;
}

.recommend-card {
  width: 218rpx;
  min-height: 316rpx;
  display: inline-block;
  margin-right: 18rpx;
  vertical-align: top;
}

.recommend-image {
  width: 218rpx;
  height: 218rpx;
  border-radius: 12rpx;
  background: #2A261D;
}

.recommend-name {
  margin-top: 12rpx;
  color: #EDE8DF;
  font-size: 24rpx;
  line-height: 1.25;
  white-space: normal;
}

.recommend-price {
  margin-top: 6rpx;
  color: #C8A055;
  font-size: 22rpx;
  font-weight: 700;
}

.actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: grid;
  grid-template-columns: minmax(0, 0.78fr) minmax(0, 1.22fr);
  align-items: center;
  gap: 16rpx;
  min-height: 144rpx;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(255,255,255,0.07);
  background: rgba(24,22,15,0.98);
}

.actions button::after {
  border: 0;
}

.share-btn,
.ghost-btn,
.action-btn {
  width: 100%;
  height: 88rpx;
  min-height: 88rpx;
  margin: 0;
  padding: 0;
  border: 0;
  box-sizing: border-box;
}

.primary-btn.small {
  width: 220rpx;
  min-height: 88rpx;
  border-radius: 44rpx;
  background: #C8A055;
  color: #18160F;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 88rpx;
}

.ghost-btn {
  border: 1rpx solid rgba(200,160,85,0.32);
  background: #2A261D;
  color: #EDE8DF;
  border-radius: 44rpx;
  font-size: 26rpx;
  line-height: 88rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  background: transparent;
  color: rgba(237,232,223,0.52);
  font-size: 22rpx;
  line-height: 1;
}

.action-btn.active {
  color: #C8A055;
}

.action-icon {
  display: block;
  height: 50rpx;
  font-size: 46rpx;
  font-weight: 400;
  line-height: 50rpx;
}

.action-label {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  line-height: 24rpx;
}

.share-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 28rpx;
  background: #C8A055;
  color: #18160F;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1;
}

.state,
.skeleton {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 32rpx;
  color: #AFA58E;
  box-sizing: border-box;
}

.state-title {
  color: #F7F1E6;
  font-size: 34rpx;
  font-weight: 700;
  text-align: center;
}

.state-subtitle {
  margin-top: 16rpx;
  color: #8D836F;
  font-size: 24rpx;
  text-align: center;
  word-break: break-word;
}

.state-actions {
  display: flex;
  gap: 18rpx;
  justify-content: center;
  margin-top: 34rpx;
}

.skeleton {
  justify-content: flex-start;
}

.skeleton-media,
.skeleton-line,
.skeleton-card {
  border-radius: 16rpx;
  background: linear-gradient(90deg, #211E16, #2A261D, #211E16);
}

.skeleton-media {
  height: 680rpx;
  margin: -32rpx -32rpx 32rpx;
  border-radius: 0;
}

.skeleton-line {
  width: 54%;
  height: 34rpx;
  margin-top: 20rpx;
}

.skeleton-line.wide {
  width: 78%;
}

.skeleton-card {
  height: 260rpx;
  margin-top: 34rpx;
}
