.page {
  min-height: 100vh;
  padding: 28rpx 28rpx calc(132rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #18160F;
  color: #EDE8DF;
}

.product-list,
.skeleton-grid {
  margin-top: 24rpx;
}

.product-grid,
.skeleton-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
  align-items: start;
}

.skeleton-card {
  min-height: 334rpx;
  overflow: hidden;
  border-radius: 18rpx;
  background: rgba(33,30,22,0.74);
  border: 2rpx solid rgba(255,255,255,0.07);
  box-sizing: border-box;
}

.skeleton-image {
  width: 100%;
  aspect-ratio: 1 / 0.86;
  background: rgba(237,232,223,0.08);
}

.skeleton-copy {
  padding: 14rpx;
  box-sizing: border-box;
}

.skeleton-line {
  height: 24rpx;
  margin-top: 14rpx;
  border-radius: 12rpx;
  background: rgba(237,232,223,0.08);
}

.skeleton-line.strong {
  width: 84%;
  margin-top: 0;
}

.skeleton-line.short {
  width: 52%;
}

.state {
  min-height: 560rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  color: rgba(237,232,223,0.58);
  font-size: 26rpx;
  line-height: 1.5;
  text-align: center;
  padding: 0 36rpx;
}

.retry-btn {
  min-height: 84rpx;
  margin-top: 28rpx;
  padding: 0 36rpx;
  border-radius: 42rpx;
  background: #C8A055;
  color: #18160F;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 84rpx;
}

.load-more {
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(237,232,223,0.48);
  font-size: 24rpx;
}

.load-more.retry {
  color: #C8A055;
}

.card-press {
  opacity: 0.78;
}
