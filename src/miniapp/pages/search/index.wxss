.page {
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 24rpx) 28rpx 140rpx;
  background: #18160F;
  color: #FFF7E8;
  box-sizing: border-box;
}

.search-safe-area {
  z-index: 5;
  position: sticky;
  top: env(safe-area-inset-top);
  min-height: 88rpx;
  padding: 0 0 18rpx;
  background: #18160F;
}

.clear-btn {
  width: 88rpx;
  height: 88rpx;
  padding: 0;
  border-radius: 44rpx;
  background: #252116;
  color: #E7D7B8;
  font-size: 36rpx;
  line-height: 88rpx;
}

.search-bar {
  flex: 1;
  min-width: 0;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 18rpx;
  border: 1rpx solid rgba(200, 160, 85, 0.35);
  border-radius: 44rpx;
  background: #221F16;
  box-sizing: border-box;
}

.search-icon {
  color: #C8A055;
  margin-right: 10rpx;
}

.search-input {
  flex: 1;
  min-height: 80rpx;
  color: #FFF7E8;
  font-size: 28rpx;
}

.search-btn,
.retry-btn,
.more-btn,
.apply-btn {
  min-width: 120rpx;
  min-height: 88rpx;
  border-radius: 44rpx;
  background: #C8A055;
  color: #18160F;
  font-size: 26rpx;
  font-weight: 700;
}

.section-head,
.drawer-head,
.filter-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 30rpx 0 18rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.text-btn {
  min-width: 88rpx;
  min-height: 56rpx;
  padding: 0 16rpx;
  background: transparent;
  color: #C8A055;
  font-size: 24rpx;
}

.recent-head .text-btn {
  min-width: auto;
  padding-right: 0;
  text-align: right;
}

.recent-head {
  width: 100%;
  box-sizing: border-box;
}

.section-title {
  flex: 1;
  min-width: 0;
}

.clear-history-btn {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex-shrink: 0;
  width: auto;
  margin: 0;
  padding-left: 16rpx;
  line-height: 56rpx;
}

.chip-row,
.quick-filters {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.keyword-chip,
.history-chip,
.filter-chip {
  min-height: 64rpx;
  padding: 0 22rpx;
  border-radius: 32rpx;
  background: #252116;
  color: #E7D7B8;
  font-size: 24rpx;
  line-height: 64rpx;
}

.history-chip {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
}

.history-chip button {
  width: 44rpx;
  height: 44rpx;
  padding: 0;
  color: #C8A055;
  line-height: 44rpx;
  background: transparent;
}

.filter-chip.selected,
.tab.active {
  border: 1rpx solid #C8A055;
  background: rgba(200, 160, 85, 0.18);
  color: #F1D99B;
}

.soft-state,
.state {
  min-height: 280rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  color: #AFA38F;
  text-align: center;
}

.suggest-panel,
.result-panel,
.search-home {
  min-height: 720rpx;
}

.suggest-row {
  min-height: 96rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  border-bottom: 1rpx solid rgba(255, 247, 232, 0.08);
}

.suggest-group {
  margin-bottom: 18rpx;
}

.suggest-group-title {
  margin: 28rpx 0 10rpx;
  color: #AFA38F;
  font-size: 24rpx;
}

.suggest-type {
  min-width: 96rpx;
  color: #C8A055;
  font-size: 22rpx;
}

.suggest-text {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tab-scroll {
  width: 100%;
  white-space: nowrap;
  margin-top: 10rpx;
}

.tab {
  display: inline-flex;
  min-width: 132rpx;
  min-height: 68rpx;
  margin-right: 12rpx;
  align-items: center;
  justify-content: center;
  border-radius: 34rpx;
  background: #252116;
  color: #CFC2A8;
  font-size: 24rpx;
}

.filter-btn {
  min-width: 112rpx;
  min-height: 64rpx;
  border-radius: 32rpx;
  background: #302A1C;
  color: #F1D99B;
}

.quick-filters {
  flex: 1;
  min-width: 0;
  flex-direction: column;
}

.quick-filter-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-height: 64rpx;
}

.quick-filter-label {
  width: 64rpx;
  flex: 0 0 64rpx;
  color: #AFA38F;
  font-size: 22rpx;
}

.result-list {
  margin-top: 22rpx;
}

.result-list.compact {
  margin-top: 12rpx;
}

.best-match,
.result-card {
  margin-bottom: 18rpx;
  border: 1rpx solid rgba(200, 160, 85, 0.18);
  border-radius: 20rpx;
  background: #211E15;
}

.best-match {
  padding: 20rpx;
  color: #F1D99B;
}

.best-match text {
  display: block;
  margin-bottom: 8rpx;
  color: #C8A055;
  font-size: 22rpx;
}

.result-section {
  margin-bottom: 18rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(255, 247, 232, 0.08);
  border-radius: 20rpx;
  background: #1D1A12;
}

.result-section-head,
.section-result-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.result-section-head {
  margin-bottom: 12rpx;
  color: #F1D99B;
  font-size: 26rpx;
  font-weight: 700;
}

.section-result-row {
  min-height: 76rpx;
  gap: 14rpx;
  border-top: 1rpx solid rgba(255, 247, 232, 0.07);
}

.section-result-type {
  flex: 0 0 96rpx;
  color: #C8A055;
  font-size: 22rpx;
}

.section-result-title {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-align: right;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.result-card {
  min-height: 188rpx;
  display: flex;
  gap: 18rpx;
  padding: 16rpx;
  box-sizing: border-box;
}

.result-image {
  width: 156rpx;
  height: 156rpx;
  border-radius: 16rpx;
  flex: 0 0 156rpx;
  background: #302A1C;
}

.result-info {
  min-width: 0;
  flex: 1;
}

.product-name {
  font-size: 30rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-meta {
  margin-top: 8rpx;
  color: #AFA38F;
  font-size: 24rpx;
}

.product-price {
  margin-top: 10rpx;
  color: #F1D99B;
  font-weight: 700;
}

.empty-title {
  color: #FFF7E8;
  font-size: 32rpx;
  font-weight: 700;
}

.empty-icon {
  width: 112rpx;
  height: 112rpx;
  margin-bottom: 22rpx;
  border: 1rpx solid rgba(200, 160, 85, 0.35);
  border-radius: 56rpx;
  color: #C8A055;
  font-size: 52rpx;
  line-height: 112rpx;
  text-align: center;
}

.empty-copy {
  margin: 16rpx 0 22rpx;
}

.empty-suggestions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 24rpx;
  color: #AFA38F;
  font-size: 24rpx;
}

.center {
  justify-content: center;
}

.drawer-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 20;
  background: rgba(0, 0, 0, 0.62);
}

.filter-drawer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 21;
  min-height: 72vh;
  max-height: 72vh;
  padding: 28rpx 28rpx 48rpx;
  border-radius: 28rpx 28rpx 0 0;
  background: #211E15;
  box-sizing: border-box;
  overflow-y: auto;
}

.facet-title {
  margin: 26rpx 0 14rpx;
  color: #C8A055;
  font-weight: 700;
}

.price-range-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 16rpx;
}

.price-input {
  flex: 1;
  min-width: 0;
  min-height: 76rpx;
  padding: 0 20rpx;
  border: 1rpx solid rgba(200, 160, 85, 0.28);
  border-radius: 18rpx;
  background: #18160F;
  color: #FFF7E8;
  font-size: 26rpx;
  box-sizing: border-box;
}

.price-separator {
  color: #AFA38F;
}

.apply-btn {
  width: 100%;
  margin-top: 36rpx;
}
.section-result-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-height: 104rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 8rpx;
  background: rgba(24,22,15,0.88);
}

.section-result-main {
  display: flex;
  align-items: center;
  min-width: 0;
  gap: 16rpx;
}

.section-result-card .section-result-title {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.section-result-meta {
  flex-shrink: 0;
  max-width: 220rpx;
  color: rgba(237,232,223,0.5);
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.section-result-product-card {
  display: grid;
  grid-template-columns: 188rpx minmax(0, 1fr);
  gap: 22rpx;
  min-height: 188rpx;
  padding: 18rpx;
  margin-bottom: 18rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 8rpx;
  background: rgba(24,22,15,0.88);
  box-sizing: border-box;
}

.section-card-image-frame {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 154rpx;
  border-radius: 8rpx;
  background: #211E15;
  color: #C8A055;
  font-size: 24rpx;
  font-weight: 700;
}

.section-card-content {
  display: flex;
  min-width: 0;
  flex-direction: column;
  justify-content: center;
  gap: 10rpx;
}

.section-card-name,
.section-card-brand,
.section-card-spec,
.section-card-price {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.section-card-name {
  color: #EDE8DF;
  font-size: 28rpx;
  font-weight: 700;
}

.section-card-brand,
.section-card-spec {
  color: rgba(237,232,223,0.62);
  font-size: 24rpx;
}

.section-card-price {
  color: #C8A055;
  font-size: 24rpx;
  font-weight: 700;
}

.section-card-price text {
  margin-right: 12rpx;
  color: rgba(237,232,223,0.5);
  font-size: 22rpx;
  font-weight: 400;
}
