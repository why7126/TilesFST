<view class="page">
  <custom-navigation title="{{searchMode == 'result' ? normalizedKeyword : '搜索'}}" />
  <view wx:if="{{searchMode != 'result'}}" class="search-safe-area">
    <search-entry
      keyword="{{keyword}}"
      scope="{{scope}}"
      source-page="{{sourcePage}}"
      show-back="{{false}}"
      disabled="{{loading}}"
      bind:input="onSearchEntryInput"
      bind:submit="onSearchEntrySubmit"
      bind:clear="clearKeyword"
      bind:cancel="cancelSearch"
    />
  </view>

  <view wx:if="{{searchMode == 'home'}}" class="search-home">
    <view wx:if="{{recentSearches.length}}" class="section-head recent-head">
      <text class="section-title">最近搜索</text>
      <button class="text-btn clear-history-btn" bindtap="clearHistory">清空</button>
    </view>
    <view wx:if="{{recentSearches.length}}" class="chip-row">
      <view wx:for="{{recentSearches}}" wx:key="*this" class="history-chip">
        <text bindtap="useKeyword" data-keyword="{{item}}">{{item}}</text>
        <button bindtap="deleteHistory" data-keyword="{{item}}">×</button>
      </view>
    </view>

    <view class="section-head"><text>热门搜索</text></view>
    <view class="chip-row">
      <button wx:for="{{hotKeywords}}" wx:key="*this" class="keyword-chip" bindtap="useKeyword" data-keyword="{{item}}">
        {{item}}
      </button>
    </view>
  </view>

  <view wx:elif="{{searchMode == 'suggest'}}" class="suggest-panel">
    <view wx:if="{{suggesting}}" class="soft-state">正在联想...</view>
    <view wx:if="{{brandSuggestions.length}}" class="suggest-group-title">品牌</view>
    <view
      wx:for="{{brandSuggestions}}"
      wx:key="id"
      class="suggest-row"
      bindtap="openSuggestion"
      data-item="{{item}}"
    >
      <text class="suggest-type">{{item.group_label || item.entity_type}}</text>
      <text class="suggest-text">{{item.text}}</text>
    </view>
    <view wx:if="{{skuSuggestions.length}}" class="suggest-group-title">SKU</view>
    <view
      wx:for="{{skuSuggestions}}"
      wx:key="id"
      class="suggest-row"
      bindtap="openSuggestion"
      data-item="{{item}}"
    >
      <text class="suggest-type">{{item.group_label || item.entity_type}}</text>
      <text class="suggest-text">{{item.text}}</text>
    </view>
  </view>

  <view wx:else class="result-panel">
    <scroll-view class="tab-scroll" scroll-x>
      <button
        wx:for="{{tabs}}"
        wx:key="value"
        class="tab {{item.selected ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="{{item.value}}"
      >
        {{item.label}} {{item.count}}
      </button>
    </scroll-view>

    <view wx:if="{{loading}}" class="state">加载中...</view>
    <view wx:elif="{{error}}" class="state">
      <view>{{error}}</view>
      <button class="retry-btn" bindtap="retrySearch">重试</button>
    </view>
    <view wx:elif="{{!hasResults}}" class="state empty-state">
      <view class="empty-icon">⌕</view>
      <view class="empty-title">没有找到“{{normalizedKeyword}}”</view>
      <view class="empty-copy">可以尝试下面的调整方式</view>
      <view class="empty-suggestions">
        <view>检查 SKU 编码或型号是否完整</view>
        <view>缩短关键词，只保留品牌、规格或名称</view>
        <view>替换相近品牌、类目或规格重新搜索</view>
      </view>
      <view class="chip-row center">
        <button wx:for="{{recommendedKeywords}}" wx:key="*this" class="keyword-chip" bindtap="useKeyword" data-keyword="{{item}}">
          {{item}}
        </button>
      </view>
    </view>

    <view wx:else class="result-list">
      <view wx:if="{{activeTab == 'all' && bestMatch}}" class="best-match">
        <text>最佳匹配</text>
        <product-card
          wx:if="{{bestMatch.entity_type == 'sku' || bestMatch.product_id}}"
          product="{{bestMatch}}"
          density="list"
          source-page="search"
          source-module="best_match"
          keyword="{{normalizedKeyword}}"
          list-context="best_match"
          index="0"
          request-id="{{requestId}}"
          image-fallback="{{imageFallback}}"
          bindcardtap="rememberProduct"
        />
        <view wx:else class="section-result-product-card" bindtap="openSectionItem" data-item="{{bestMatch}}">
          <view class="section-card-image-frame">
            <text>{{bestMatch.entity_type == 'brand' ? '品牌' : '匹配'}}</text>
          </view>
          <view class="section-card-content">
            <view class="section-card-name">{{bestMatch.title || bestMatch.name}}</view>
            <view class="section-card-brand">{{bestMatch.entity_type == 'brand' ? '品牌' : '搜索结果'}}</view>
            <view class="section-card-spec">{{bestMatch.count ? bestMatch.count + ' 个公开 SKU' : '查看详情'}}</view>
            <view class="section-card-price"><text>最佳匹配</text>{{bestMatch.title || bestMatch.name}}</view>
          </view>
        </view>
      </view>
      <block wx:if="{{activeTab == 'all'}}">
        <view wx:for="{{displaySections}}" wx:key="title" class="result-section">
          <view class="result-section-head">
            <text>{{item.title}}</text>
            <text>{{item.count}} 条</text>
          </view>
          <view wx:if="{{item.entity_type == 'sku'}}" class="section-product-list">
            <product-card
              wx:for="{{item.items}}"
              wx:for-item="sectionItem"
              wx:key="id"
              product="{{sectionItem}}"
              density="list"
              source-page="search"
              source-module="section_sku"
              keyword="{{normalizedKeyword}}"
              list-context="section_sku"
              index="{{index}}"
              request-id="{{requestId}}"
              image-fallback="{{imageFallback}}"
              bindcardtap="rememberProduct"
            />
          </view>
          <block wx:else>
            <view wx:for="{{item.items}}" wx:for-item="sectionItem" wx:key="id" class="section-result-product-card" bindtap="openSectionItem" data-item="{{sectionItem}}">
              <view class="section-card-image-frame">
                <text>{{item.card_label}}</text>
              </view>
              <view class="section-card-content">
                <view class="section-card-name">{{sectionItem.product_name || sectionItem.name || sectionItem.title || sectionItem.label || sectionItem.sku_code}}</view>
                <view class="section-card-brand">{{item.card_label}}</view>
                <view class="section-card-spec">{{sectionItem.subtitle || sectionItem.type || sectionItem.certificate_no || '信息待补充'}}</view>
                <view class="section-card-price"><text>相关信息</text>{{sectionItem.sku_code || sectionItem.certificate_no || sectionItem.count || '查看详情'}}</view>
              </view>
            </view>
          </block>
        </view>
      </block>
      <block wx:elif="{{activeDisplaySection}}">
        <view wx:if="{{activeDisplaySection.entity_type == 'sku'}}" class="section-product-list">
          <product-card
            wx:for="{{activeDisplaySection.items}}"
            wx:for-item="sectionItem"
            wx:key="id"
            product="{{sectionItem}}"
            density="list"
            source-page="search"
            source-module="section_sku"
            keyword="{{normalizedKeyword}}"
            list-context="section_sku"
            index="{{index}}"
            request-id="{{requestId}}"
            image-fallback="{{imageFallback}}"
            bindcardtap="rememberProduct"
          />
        </view>
        <block wx:else>
          <view wx:for="{{activeDisplaySection.items}}" wx:for-item="sectionItem" wx:key="id" class="section-result-product-card" bindtap="openSectionItem" data-item="{{sectionItem}}">
            <view class="section-card-image-frame">
              <text>{{activeDisplaySection.card_label}}</text>
            </view>
            <view class="section-card-content">
              <view class="section-card-name">{{sectionItem.product_name || sectionItem.name || sectionItem.title || sectionItem.label || sectionItem.sku_code}}</view>
              <view class="section-card-brand">{{activeDisplaySection.card_label}}</view>
              <view class="section-card-spec">{{sectionItem.subtitle || sectionItem.type || sectionItem.certificate_no || '信息待补充'}}</view>
              <view class="section-card-price"><text>相关信息</text>{{sectionItem.sku_code || sectionItem.certificate_no || sectionItem.count || '查看详情'}}</view>
            </view>
          </view>
        </block>
      </block>
      <button wx:if="{{hasMore && !loading}}" class="more-btn" bindtap="loadMore">加载更多</button>
    </view>
  </view>

</view>
