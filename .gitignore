# OS / editor
.DS_Store

# Local environment
.env
.env.local
.venv/

# Python
__pycache__/
*.pyc
.pytest_cache/
coverage/

# Node / frontend build
node_modules/
dist/
build/

# Local databases and object-store runtime files
*.sqlite3
*.db
.minio/

# Runtime data: keep directory structure, ignore generated data and uploaded media
/data/runtime/**
/data/sqlite/*.db
/data/sqlite/*.sqlite
/data/sqlite/*.sqlite3
/data/uploads/**
/data/processed/**
/data/tmp/**
/data/minio/**

# AI usage observability: keep raw/local extraction inputs out of git.
/data/ai-usage/raw/**
/data/ai-usage/local/**
/data/ai-usage/**/*.jsonl

# Product release docs: keep source, ignore generated Mintlify output
/releases/.mintlify/**
/releases/dist/**
/releases/build/**

# Keep placeholders and documentation
!/data/**/.gitkeep
!/data/README.md
!/data/ai-usage/README.md
!/data/ai-usage/samples/**
!/data/samples/**
