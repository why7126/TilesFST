# ==============================================================================
# TilesFST - Image Build Environment Example
# ==============================================================================
# 复制为 scripts/build-images.env 后按需修改；真实构建配置不要提交。
# 维护要求：新增或修改变量时，必须在变量上一行同步补充用途、取值范围或安全边界注释。

# 镜像版本 tag；建议与产品版本或交付版本一致，例如 v0.0.1。
IMAGE_BUILD_TAG=v0.0.1
# 构建目标平台；离线交付给 x86_64 Linux 服务器时使用 linux/amd64。
IMAGE_BUILD_PLATFORM=linux/amd64

# 后端镜像仓库名；脚本会拼接为 ${IMAGE_BUILD_BACKEND_IMAGE}:${IMAGE_BUILD_TAG}。
IMAGE_BUILD_BACKEND_IMAGE=tilesfst-backend
# Web 镜像仓库名；脚本会拼接为 ${IMAGE_BUILD_WEB_IMAGE}:${IMAGE_BUILD_TAG}。
IMAGE_BUILD_WEB_IMAGE=tilesfst-web

# buildx builder 名称；脚本可自动创建或复用该 builder。
IMAGE_BUILD_BUILDER=tilesfst-builder
# 是否在缺少 builder 时自动创建；本地构建通常为 true。
IMAGE_BUILD_CREATE_BUILDER=true
# 是否将构建结果加载到本地 Docker image store；离线导出和本地验证必须为 true。
IMAGE_BUILD_LOAD=true

# 是否导出包含 backend/web 的 gzip 离线镜像包。
IMAGE_BUILD_EXPORT_TAR=true
# 离线交付输出目录；建议放在项目仓库外，避免大镜像包进入 Git 工作区。
IMAGE_BUILD_RELEASE_DIR=../releases/v0.0.1
# 离线镜像包文件名；平台建议写入文件名，便于服务器侧识别。
IMAGE_BUILD_TAR_NAME=tilesfst-v0.0.1-linux-amd64.tar.gz
