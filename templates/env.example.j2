# 文档用途：项目根环境变量示例
# 文档内容：Docker Compose、本地开发、后端、前端、MinIO、SQLite、视频处理相关环境变量
# 内容来源：project.yaml + AI自动生成
# 更新方式：新增服务、端口、密钥、存储、数据库、视频处理配置时必须同步更新
# 备注：复制为 .env 后使用，.env 不允许提交 Git

PROJECT_NAME={{ project.code }}
APP_ENV=development
LOG_LEVEL=INFO
BACKEND_PORT=8000
WEB_PORT=3000
VITE_API_BASE_URL=http://localhost:8000
LOCAL_SQLITE_DATABASE_URL=sqlite:///./data/sqlite/{{ project.code }}.db
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_TILE_IMAGES=tile-images
MINIO_BUCKET_TILE_VIDEOS=tile-videos
MINIO_BUCKET_TILE_DOCUMENTS=tile-documents
MAX_IMAGE_SIZE_MB=20
MAX_VIDEO_SIZE_MB=500
VIDEO_PROCESSING_ENABLED=true
VIDEO_TRANSCODE_ENABLED=false
VIDEO_THUMBNAIL_ENABLED=true
