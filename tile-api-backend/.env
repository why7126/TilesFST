# Database
DATABASE_URL=sqlite:///./tiles.db

# MinIO Object Storage (using local dev setup)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=tiles
MINIO_REGION=us-east-1
MINIO_SECURE=false

# JWT Settings
JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# App Settings
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true