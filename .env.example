# ==============================================================================
# Tile Info Platform - Environment Variables Example
# ==============================================================================
# 复制本文件为 .env 后按需修改；禁止提交真实 .env、密钥、生产地址。
# 维护要求：新增或修改任一变量时，必须在变量上一行同步补充用途、取值范围或安全边界注释。

# 后端生产镜像名；离线镜像包部署时由交付版 docker-compose.yml 的 image 使用。
TILESFST_BACKEND_IMAGE=tilesfst-backend:v0.0.4
# Web 生产镜像名；离线镜像包部署时由交付版 docker-compose.yml 的 image 使用。
TILESFST_WEB_IMAGE=tilesfst-web:v0.0.4

# 应用标识，用于日志与内部命名。
APP_NAME=tilesfst
# 运行环境：development / staging / production；production 必须配置 MySQL DATABASE_URL。
APP_ENV=development
# 是否开启调试模式；生产环境 MUST 设为 false。
APP_DEBUG=true
# JWT 签名与敏感操作密钥；本地使用示例值，生产 MUST 通过密钥管理系统注入。
APP_SECRET_KEY=change-me-in-local-env
# JWT 访问令牌有效期（分钟）；「记住我」未勾选时使用。
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
# JWT 访问令牌有效期（天）；登录勾选「记住我」时使用。
JWT_REMEMBER_ME_EXPIRE_DAYS=7

# 默认管理员用户名；仅首次创建空库 admin 账号时使用。
ADMIN_USERNAME=admin
# 默认管理员初始密码；首次建库或显式恢复开关启用时生效，生产 MUST 修改。
ADMIN_INITIAL_PASSWORD=change-me-on-first-run
# 是否在服务启动时将 admin 密码重置为 ADMIN_INITIAL_PASSWORD；默认 false，仅本地/演示临时启用。
ADMIN_RESET_PASSWORD_ON_STARTUP=false

# Docker 宿主机映射的后端 API 端口；容器内固定 8000，多项目冲突时改此项。
HOST_PORT_BACKEND=8000
# Docker 宿主机映射的 Web 前端端口；容器内 Nginx 固定 80。
HOST_PORT_WEB=3000
# Docker 宿主机映射的 MinIO S3 API 端口；容器内固定 9000。
HOST_PORT_MINIO_API=9000
# Docker 宿主机映射的 MinIO Console 管理界面端口；容器内固定 9001。
HOST_PORT_MINIO_CONSOLE=9001

# 后端 FastAPI 监听地址；Docker 内通常为 0.0.0.0。
BACKEND_HOST=0.0.0.0
# 后端容器内监听端口；与 docker-compose 映射的容器侧端口一致，一般勿改。
BACKEND_PORT=8000
# 允许跨域的前端 Origin 列表，逗号分隔；需包含 Web 访问地址。
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# 前端构建或直连后端时使用的 API 基址；Docker Web 经 Nginx 反代时可指向 backend 服务。
VITE_API_BASE_URL=http://localhost:8000
# 统一数据库连接 URL；本地/demo 默认 SQLite，production MUST 覆盖为 MySQL 8.0+。
# 生产示例：mysql+pymysql://tiles_user:replace-with-secret@mysql.example.com:3306/tilesfst?charset=utf8mb4
DATABASE_URL=sqlite:////app/data/sqlite/tilesfst.db

# 对象存储提供方：minio / self-hosted-minio / s3-compatible / tencent-cos / volcengine-tos。
OBJECT_STORAGE_PROVIDER=minio
# 对象存储 S3 兼容 endpoint（host:port，不含 http/https）；本地 MinIO 使用 minio:9000。
OBJECT_STORAGE_ENDPOINT=minio:9000
# 对象存储访问密钥；生产 MUST 通过密钥管理注入。
OBJECT_STORAGE_ACCESS_KEY=minioadmin
# 对象存储秘密密钥；示例值仅用于本地，禁止提交真实值。
OBJECT_STORAGE_SECRET_KEY=minioadmin
# 是否使用 HTTPS 连接对象存储；本地 Docker 为 false，COS/TOS 通常为 true。
OBJECT_STORAGE_SECURE=false
# 对象存储 Bucket；云上 COS/TOS 等场景必须由运维提前创建。
OBJECT_STORAGE_BUCKET=tilesfst
# 对象存储区域；COS/TOS 等云上 S3 兼容服务通常必填，本地 MinIO 可留空。
OBJECT_STORAGE_REGION=
# 是否使用 path-style 访问；MinIO 通常为 true，部分云厂商 virtual-host 风格可设为 false。
OBJECT_STORAGE_PATH_STYLE=true
# 是否允许应用自动创建 Bucket；本地/自建 MinIO 可 true，云上对象存储生产 MUST 为 false。
OBJECT_STORAGE_AUTO_CREATE_BUCKET=true

# V5 单桶策略：一个项目一个 Bucket，桶内用前缀区分资源类型。
# 图片类上传对象前缀（头像、Logo、SKU 图等）。
OBJECT_STORAGE_PREFIX_IMAGES=images/
# Deprecated：legacy 图片前缀；新上传 MUST 使用 OBJECT_STORAGE_PREFIX_IMAGES。
OBJECT_STORAGE_PREFIX_ORIGINAL=original/
# 文档类对象前缀（预留）。
OBJECT_STORAGE_PREFIX_FILES=files/
# 音频类对象前缀（预留）。
OBJECT_STORAGE_PREFIX_AUDIOS=audios/
# 缩略图对象前缀。
OBJECT_STORAGE_PREFIX_THUMBNAILS=thumbnails/
# 后端处理产物对象前缀。
OBJECT_STORAGE_PREFIX_PROCESSED=processed/
# 临时上传/中间文件对象前缀。
OBJECT_STORAGE_PREFIX_TEMP=tmp/
# 数据导入文件对象前缀。
OBJECT_STORAGE_PREFIX_IMPORT=imports/
# 数据导出文件对象前缀。
OBJECT_STORAGE_PREFIX_EXPORT=exports/
# 视频原文件对象前缀。
OBJECT_STORAGE_PREFIX_VIDEO=videos/
# 视频封面图对象前缀。
OBJECT_STORAGE_PREFIX_VIDEO_COVER=videos/covers/
# 视频转码输出对象前缀（VIDEO_TRANSCODE_ENABLED 启用时使用）。
OBJECT_STORAGE_PREFIX_VIDEO_TRANSCODED=videos/transcoded/

# 本地开发数据根目录（相对项目根）；Docker 卷映射见 docker-compose.yml。
DATA_ROOT=./data

# 单张图片上传大小上限（MB）；须 ≤ Web Nginx client_max_body_size。
MAX_IMAGE_SIZE_MB=20
# 允许的图片 MIME 类型，逗号分隔。
ALLOWED_IMAGE_TYPES=image/jpeg,image/jpg,image/png,image/webp,image/gif,image/svg+xml,image/bmp,image/tiff,image/heic

# 单个视频上传大小上限（MB）；须 ≤ Web Nginx client_max_body_size。
MAX_VIDEO_SIZE_MB=500
# 单个文档 / 证书文件上传大小上限（MB）；须 ≤ Web Nginx client_max_body_size。
MAX_FILE_SIZE_MB=25
# 允许的视频 MIME 类型，逗号分隔。
ALLOWED_VIDEO_TYPES=video/mp4,video/quicktime,video/x-msvideo,video/webm,video/x-matroska,video/mpeg,video/3gpp

# 后端本地处理产物目录（Docker 卷 ./data/processed）；非 MinIO 业务对象存储路径。
PROCESSED_DIR=/app/data/processed
# 后端临时文件目录（Docker 卷 ./data/tmp）。
TMP_DIR=/app/data/tmp

# 是否启用视频上传与管理能力。
VIDEO_ENABLED=true
# 上传视频后是否自动生成封面图。
VIDEO_GENERATE_COVER=true
# 是否启用视频转码（可选增强，默认关闭）。
VIDEO_TRANSCODE_ENABLED=false
